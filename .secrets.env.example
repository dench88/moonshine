# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Search
TAVILY_API_KEY=tvly-...
BRAVE_API_KEY=

# Online LLM providers (only needed if using anthropic/* or openai/* or deepseek/* models in config.py)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
